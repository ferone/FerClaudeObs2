    "engineering": ["discipline", "project", "revision", "approval_status"],
    "research": ["topic", "methodology", "period", "key_findings"]
  },
  "type_inference_patterns": {
    "regulation": ["DOE", "ERC", "NGCP", "RA", "DC", "circular", "order", "act", "code"],
    "project": ["project", "MW", "MWh", "construction", "COD"],
    "analysis": ["analysis", "brief", "report", "forecast", "assessment"],
    "technology": ["solar", "BESS", "wind", "inverter", "PCS", "SCADA", "battery"],
    "company": ["company", "corp", "ltd", "inc", "holdings"],
    "supplier": ["supplier", "manufacturer", "vendor", "OEM"],
    "brief": ["weekly", "brief", "summary", "digest"],
    "meeting": ["meeting", "minutes", "transcript", "agenda", "attendees", "MOM"],
    "procurement": ["tender", "RFP", "RFQ", "bid", "proposal", "evaluation", "procurement"],
    "quotation": ["quotation", "quote", "pricing", "offer", "commercial proposal", "unit price"],
    "engineering": ["SIS", "SLD", "sizing", "calculation", "compatibility", "specification", "technical study", "design document"],
    "research": ["deep dive", "deep analysis", "forecast", "investigation", "topic study", "lessons learned"],
    "republic_act": ["RA ", "Republic Act"],
    "doe_circular": ["DC20", "DOE DC", "department circular"],
    "erc_issuance": ["ERC-Res", "ERC-Case", "ERC resolution"],
    "energy_plan": ["PEP", "PDP", "NREP", "NTER", "roadmap", "development plan"],
    "securities_research": ["securities", "brokerage", "investment strategy", "deep report"]
  },
  "obsidian_plugins": [
    "dataview",
    "templater-obsidian",
    "smart-connections",
    "copilot",
    "graph-analysis",
    "obsidian-claudian",
    "folder-notes",
    "periodic-notes",
    "obsidian-kanban",
    "obsidian-excalidraw-plugin",
    "table-editor-obsidian",
    "tag-wrangler",
    "smart-second-brain"
  ],
  "ollama": {
    "endpoint": "http://localhost:11434",
    "model_extraction": "qwen2.5:32b",
    "model_enrichment": "qwen2.5:32b",
    "fallback_model": "qwen2.5:7b"
  },
  "processing": {
    "primary_engine": "claude-code",
    "fallback_engine": "ollama",
    "confidential_engine": "ollama",
    "confidential_mode": "zones",
    "lm_studio": {
      "endpoint": "http://127.0.0.1:1234/v1",
