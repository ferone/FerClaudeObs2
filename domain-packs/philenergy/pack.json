{
  "name": "philenergy",
  "display_name": "Philippine Energy Intelligence",
  "version": "1.0.0",
  "description": "Philippine energy market intelligence for Vivant Energy Corporation",
  "entity_categories": [
    "organizations",
    "companies_philippines",
    "suppliers_global",
    "regulations",
    "technologies",
    "market_concepts",
    "locations_philippines"
  ],
  "privacy_zones": [
    {
      "path": "10 - VIVANT INTERNAL",
      "level": "confidential",
      "external_api": false
    },
    {
      "path": "08 - COMPETITORS",
      "level": "sensitive",
      "external_api": "approval_required"
    },
    {
      "path": "13 - ENGINEERING & TECHNICAL",
      "level": "sensitive",
      "external_api": "approval_required"
    }
  ],
  "frontmatter_extensions": {
    "company": ["country", "sector", "market_cap", "founded", "employees", "revenue_usd"],
    "regulation": ["issuing_body", "document_number", "date_issued", "effective_date", "scope"],
    "technology": ["maturity", "relevant_sectors", "key_players"],
